FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    apache2 \
    libapache2-mod-auth-gssapi \
    krb5-user \
    openssl \
    ca-certificates \
    gettext-base \
    && rm -rf /var/lib/apt/lists/*

RUN a2enmod ssl && a2enmod include && a2enmod auth_gssapi && a2enmod authn_core && a2enmod authz_core

COPY config/krb5.conf /etc/krb5.conf
COPY config/ports.conf /etc/apache2/ports.conf
COPY config/web1-ssl.conf /etc/apache2/sites-available/web1-ssl.conf
COPY app/ /var/www/html/

RUN a2ensite web1-ssl && a2dissite 000-default

COPY scripts/init-web.sh /usr/local/bin/init-web.sh
COPY scripts/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/*.sh

EXPOSE 443

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]