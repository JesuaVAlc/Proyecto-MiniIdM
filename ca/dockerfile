FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    openssl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /etc/fis-ca

COPY scripts/init-ca.sh /usr/local/bin/init-ca.sh
COPY scripts/sign-cert.sh /usr/local/bin/sign-cert.sh
RUN chmod +x /usr/local/bin/init-ca.sh /usr/local/bin/sign-cert.sh

ENTRYPOINT ["/usr/local/bin/init-ca.sh"]
CMD ["tail", "-f", "/dev/null"]